<Window x:Class="HVACCalculator.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HVAC Calculator - Versie 2026.1" SizeToContent="WidthAndHeight" Background="#FF002262" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Icon="/Resources/VA.ico">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="#FF0264C9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        <Style TargetType="StackPanel" x:Key="CalculatorItemStyle">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="20,10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="CalculatorNameStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="300"/>
        </Style>
    </Window.Resources>
    
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
        <TextBlock Text="Selecteer een calculator" Style="{StaticResource HeaderStyle}"/>
        
        <StackPanel Style="{StaticResource CalculatorItemStyle}">
            <TextBlock Text="Luchtkanaal calculator" Style="{StaticResource CalculatorNameStyle}"/>
            <Button Content="Start" Click="btnStartAirDuct_Click"/>
        </StackPanel>
        
        <StackPanel Style="{StaticResource CalculatorItemStyle}">
            <TextBlock Text="CV / GKW buis calculator" Style="{StaticResource CalculatorNameStyle}"/>
            <Button Content="Start" Click="btnStartCVGKW_Click"/>
        </StackPanel>
        
        <StackPanel Style="{StaticResource CalculatorItemStyle}">
            <TextBlock Text="Tapwater buis calculator" Style="{StaticResource CalculatorNameStyle}"/>
            <Button Content="Start" Click="btnStartTapwater_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
