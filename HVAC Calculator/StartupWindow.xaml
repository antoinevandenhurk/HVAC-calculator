<Window x:Class="HVACCalculator.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Source={x:Static Application.Current}, Path=Resources[AppVersion], StringFormat=HVAC Calculator - Versie {0}}" SizeToContent="WidthAndHeight" Background="#FF002262" WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize" Icon="/Resources/VA.ico">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="#FF0264C9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        <Style x:Key="ToolLaunchButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="380"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="0,3,0,3"/>
        </Style>
        <Style x:Key="GearButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF0264C9"/>
            <Setter Property="BorderBrush" Value="#FF1D8BF0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="circle"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="{TemplateBinding BorderThickness}"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="circle" Property="Fill" Value="#FF1D8BF0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="circle" Property="Fill" Value="#FF014B98"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="StackPanel" x:Key="CalculatorItemStyle">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="20,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="CalculatorNameStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="300"/>
        </Style>
    </Window.Resources>
    
<Grid>
        <!-- Info en instellingen knoppen rechtsbovenaan -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0">
            <Button Content="i" Click="btnInfo_Click" Style="{StaticResource GearButtonStyle}" Margin="0,0,6,0" ToolTip="Informatie"/>
            <Button Content="⚙" Click="btnSettings_Click" Style="{StaticResource GearButtonStyle}" ToolTip="Instellingen"/>
        </StackPanel>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
            <TextBlock Text="Selecteer een tool" Style="{StaticResource HeaderStyle}"/>

            <Border BorderBrush="#FF0264C9" BorderThickness="1" Padding="8" CornerRadius="4">
                <ScrollViewer Height="188" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Button Content="01. CV / GKW buis calculator" Style="{StaticResource ToolLaunchButtonStyle}" Click="btnStartCVGKW_Click"/>
                        <Button Content="02. Gebruikers modulen" Style="{StaticResource ToolLaunchButtonStyle}" Click="btnStartGebruikersModulen_Click"/>
                        <Button Content="03. Kanalen ballast" Style="{StaticResource ToolLaunchButtonStyle}" Click="btnStartKanalenBallast_Click"/>
                        <Button Content="04. Leiding ballast" Style="{StaticResource ToolLaunchButtonStyle}" Click="btnStartLeidingballast_Click"/>
                        <Button Content="05. Luchtkanaal calculator" Style="{StaticResource ToolLaunchButtonStyle}" Click="btnStartAirDuct_Click"/>
                        <Button Content="06. Mengwater calculator" Style="{StaticResource ToolLaunchButtonStyle}" Click="btnStartMengwater_Click"/>
                        <Button Content="07. Tapwater buis calculator" Style="{StaticResource ToolLaunchButtonStyle}" Click="btnStartTapwater_Click"/>
                        <Button Content="08. Warm tapwater circulatie" Style="{StaticResource ToolLaunchButtonStyle}" Click="btnStartWarmTapwaterCirculatie_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </StackPanel>
    </Grid>
</Window>


