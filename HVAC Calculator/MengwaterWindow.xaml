<Window x:Class="HVACCalculator.MengwaterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mengwater Calculator - Versie 2026.1" SizeToContent="WidthAndHeight" Background="#FF002262" WindowStartupLocation="Manual" ResizeMode="CanMinimize" Topmost="True" Icon="/Resources/VA.ico">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Width" Value="100"/>
            <EventSetter Event="GotFocus" Handler="TextBox_GotFocus"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5,20,5,2"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#FF0264C9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,10,0">
            <TextBlock Text="Mengwater Calculator" Style="{StaticResource HeaderStyle}" HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <Border Background="#1FFFFFFF" BorderBrush="#50FFFFFF" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,10">
                <Canvas Width="185" Height="100">
                    <Line X1="20" Y1="50" X2="165" Y2="50" Stroke="Black" StrokeThickness="2"/>
                    <Line X1="92" Y1="18" X2="92" Y2="50" Stroke="Black" StrokeThickness="2"/>

                    <Line X1="18" Y1="47" X2="42" Y2="47" Stroke="#FF1889C7" StrokeThickness="2"/>
                    <Polygon Points="42,47 35,43 35,51" Fill="#FF1889C7"/>

                    <Line X1="165" Y1="53" X2="140" Y2="53" Stroke="#FF1889C7" StrokeThickness="2"/>
                    <Polygon Points="165,53 158,49 158,57" Fill="#FF1889C7"/>

                    <Line X1="92" Y1="18" X2="92" Y2="48" Stroke="#FF1889C7" StrokeThickness="2"/>
                    <Polygon Points="92,48 88,41 96,41" Fill="#FF1889C7"/>

                    <TextBlock Canvas.Left="5" Canvas.Top="31" Text="qv1" Foreground="#FF1889C7" FontWeight="SemiBold"/>
                    <TextBlock Canvas.Left="99" Canvas.Top="20" Text="qv2" Foreground="#FF1889C7" FontWeight="SemiBold"/>
                    <TextBlock Canvas.Left="140" Canvas.Top="31" Text="qv3" Foreground="#FF1889C7" FontWeight="SemiBold"/>

                    <TextBlock Canvas.Left="0" Canvas.Top="18" Text="θ1 °C" Foreground="Red" FontWeight="SemiBold"/>
                    <TextBlock Canvas.Left="99" Canvas.Top="0" Text="θ2 °C" Foreground="Red" FontWeight="SemiBold"/>
                    <TextBlock Canvas.Left="138" Canvas.Top="55" Text="θ3 °C" Foreground="Red" FontWeight="SemiBold"/>
                </Canvas>
            </Border>

            <Grid Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,5,10,5">
                    <TextBlock Text="qv1" Style="{StaticResource LabelStyle}" Width="35"/>
                    <TextBox x:Name="i4_1" TabIndex="1"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,5,10,5">
                    <TextBlock Text="qv2" Style="{StaticResource LabelStyle}" Width="35"/>
                    <TextBox x:Name="i4_3" TabIndex="3"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="qv3" Style="{StaticResource LabelStyle}" Width="35"/>
                    <TextBox x:Name="i4_5" TabIndex="5"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,5,10,5">
                    <TextBlock Text="θ1" Style="{StaticResource LabelStyle}" Width="35"/>
                    <TextBox x:Name="i4_2" TabIndex="2"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,5,10,5">
                    <TextBlock Text="θ2" Style="{StaticResource LabelStyle}" Width="35"/>
                    <TextBox x:Name="i4_4" TabIndex="4"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="θ3" Style="{StaticResource LabelStyle}" Width="35"/>
                    <TextBox x:Name="i4_6" TabIndex="6"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Vertical">
            <Button Content="Bereken" Click="btnBereken_Click" TabIndex="7"/>
            <Button Content="Wissen" Click="btnWissen_Click" TabIndex="8" Margin="5,2"/>
            <Button Content="Afsluiten" Click="btnAfsluiten_Click" TabIndex="9" Margin="5,2"/>
            <Button Content="Info" Click="btnInfo_Click" TabIndex="10" Margin="5,2"/>
        </StackPanel>
    </Grid>
</Window>
