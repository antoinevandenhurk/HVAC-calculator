<Window x:Class="HVACCalculator.AirDuctWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HVAC Calculator - Luchtkanaal" SizeToContent="WidthAndHeight" Background="#FF002262" WindowStartupLocation="Manual" ResizeMode="NoResize" Topmost="True" Icon="/Resources/VA.ico">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <EventSetter Event="GotFocus" Handler="TextBox_GotFocus"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Background" Value="#FF0264C9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    <Grid Margin="7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="80"/><ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="5" Text="HVAC Calculator - Luchtkanaal" Style="{StaticResource HeaderStyle}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Debiet" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="i1_1" Grid.Row="1" Grid.Column="1" TabIndex="1"/>
        <TextBlock Grid.Row="1" Grid.Column="2" Text=" m³/h " Style="{StaticResource LabelStyle}"/>
        <Button Grid.Row="1" Grid.Column="3" Content="Bereken kanaal" Click="btnBerekenDebietOpp_Click" TabIndex="7"/>
        <Button Grid.Row="1" Grid.Column="4" Content="Clear" Click="btnVerwijderen_Click" TabIndex="12"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Snelheid" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="i1_2" Grid.Row="2" Grid.Column="1" TabIndex="2"/>
        <TextBlock Grid.Row="2" Grid.Column="2" Text=" m/s " Style="{StaticResource LabelStyle}"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Oppervlakte" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="i1_3" Grid.Row="3" Grid.Column="1" TabIndex="3"/>
        <TextBlock Grid.Row="3" Grid.Column="2" Text=" m² " Style="{StaticResource LabelStyle}"/>
        <Button Grid.Row="3" Grid.Column="3" Content="Bereken debiet" Click="btnBerekenDebietArea_Click" TabIndex="8"/>
        <Button Grid.Row="3" Grid.Column="4" Content="Bereken snelheid" Click="btnBerekenSnelheidOpp_Click" TabIndex="13"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Rond" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="i1_4" Grid.Row="4" Grid.Column="1" TabIndex="4"/>
        <TextBlock Grid.Row="4" Grid.Column="2" Text=" mm " Style="{StaticResource LabelStyle}"/>
        <Button Grid.Row="4" Grid.Column="3" Content="Bereken debiet" Click="btnBerekenDebietRond_Click" TabIndex="9"/>
        <Button Grid.Row="4" Grid.Column="4" Content="Bereken snelheid" Click="btnBerekenSnelheidRond_Click" TabIndex="14"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Breedte" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="i1_5" Grid.Row="5" Grid.Column="1" TabIndex="5"/>
        <TextBlock Grid.Row="5" Grid.Column="2" Text=" mm " Style="{StaticResource LabelStyle}"/>
        <Button Grid.Row="5" Grid.Column="3" Content="Bereken debiet" Click="btnBerekenDebietBxH_Click" TabIndex="10"/>
        <Button Grid.Row="5" Grid.Column="4" Content="Bereken snelheid" Click="btnBerekenSnelheidBxH_Click" TabIndex="15"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Hoogte" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="i1_6" Grid.Row="6" Grid.Column="1" TabIndex="6"/>
        <TextBlock Grid.Row="6" Grid.Column="2" Text=" mm " Style="{StaticResource LabelStyle}"/>
        <Button Grid.Row="6" Grid.Column="3" Content="Afsluiten" Click="btnAfsluiten_Click" TabIndex="11"/>
        <Button Grid.Row="6" Grid.Column="4" Content="Info" Click="btnInfo_Click" TabIndex="16"/>
    </Grid>
</Window>