<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Resources\VA.ico</ApplicationIcon>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>false</SelfContained>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Resources\VA.ico" />
    <Resource Include="Resources\ko-fi.png" />
    <Resource Include="Resources\isso_mod1.png" />
    <Resource Include="Resources\isso_mod2.png" />
    <Resource Include="Resources\isso_mod3.png" />
    <Resource Include="Resources\isso_mod4.png" />
    <Resource Include="Resources\isso_mod5.png" />
    <Resource Include="Resources\isso_mod6.png" />
    <Resource Include="Resources\isso_mod7.png" />
    <Resource Include="Resources\isso_mod8.png" />
    <Resource Include="Resources\isso_mod9.png" />
  </ItemGroup>

</Project>
