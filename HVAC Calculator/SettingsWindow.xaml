<Window x:Class="HVACCalculator.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Instellingen" SizeToContent="WidthAndHeight" Background="#FF002262"
        WindowStartupLocation="Manual" ResizeMode="CanMinimize" Topmost="True" Icon="/Resources/VA.ico">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="SectionStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="6,2,2,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Width" Value="80"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="5,15,5,2"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#FF0264C9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">
        <TextBlock Text="Leidingselectie instellingen" Style="{StaticResource HeaderStyle}" HorizontalAlignment="Center"/>

        <TextBlock Text="Stroomsnelheid CV/GKW" Style="{StaticResource SectionStyle}"/>
        <StackPanel Orientation="Horizontal" Margin="0,4">
            <TextBlock Text="Minimale waarde" Style="{StaticResource LabelStyle}" Width="200"/>
            <TextBox x:Name="tbMinVelocityCvgkw" GotFocus="TextBox_GotFocus"/>
            <TextBlock Text=" m/s" Style="{StaticResource LabelStyle}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,4">
            <TextBlock Text="Maximale waarde" Style="{StaticResource LabelStyle}" Width="200"/>
            <TextBox x:Name="tbMaxVelocityCvgkw" GotFocus="TextBox_GotFocus"/>
            <TextBlock Text=" m/s" Style="{StaticResource LabelStyle}"/>
        </StackPanel>

        <TextBlock Text="Stroomsnelheid Tapwater" Style="{StaticResource SectionStyle}"/>
        <StackPanel Orientation="Horizontal" Margin="0,4">
            <TextBlock Text="Minimale waarde" Style="{StaticResource LabelStyle}" Width="200"/>
            <TextBox x:Name="tbMinVelocityTapwater" GotFocus="TextBox_GotFocus"/>
            <TextBlock Text=" m/s" Style="{StaticResource LabelStyle}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,4">
            <TextBlock Text="Maximale waarde" Style="{StaticResource LabelStyle}" Width="200"/>
            <TextBox x:Name="tbMaxVelocityTapwater" GotFocus="TextBox_GotFocus"/>
            <TextBlock Text=" m/s" Style="{StaticResource LabelStyle}"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Opslaan" Click="btnOpslaan_Click"/>
            <Button Content="Sluiten" Click="btnSluiten_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
