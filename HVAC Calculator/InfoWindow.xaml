<Window x:Class="HVACCalculator.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Informatie" Height="250" Width="350" 
        WindowStartupLocation="Manual" ResizeMode="NoResize" 
        Background="#FF002262" Topmost="True" ShowInTaskbar="False" Icon="/Resources/VA.ico">
    
    <StackPanel Margin="15,20,15,15" HorizontalAlignment="Center" VerticalAlignment="Top">
        <TextBlock Text="HVAC calculator" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
        <TextBlock Text="Versie 2026.3" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,2"/>
        <TextBlock Text="Snelselectie van kanalen en leidingdiameters op basis van stroomsnelheden en leidingweerstand."
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,2,0,6"
                   TextWrapping="Wrap"
                   TextAlignment="Center"/>

        <TextBlock Margin="0,8,0,2" HorizontalAlignment="Center">
            <Hyperlink NavigateUri="https://github.com/antoinevandenhurk" RequestNavigate="Hyperlink_RequestNavigate">
                <Run Text="Andere projecten..." Foreground="White"/>
            </Hyperlink>
        </TextBlock>

        <TextBlock Text="All right reserved by AvdH©2026, buy me a coffee" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,10" TextWrapping="Wrap" TextAlignment="Center"/>

        <Button Click="btnKofi_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Support me on Ko-fi">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <ContentPresenter />
                </ControlTemplate>
            </Button.Template>
            <Image Source="/Resources/ko-fi.png" Width="80" Height="25" RenderOptions.BitmapScalingMode="HighQuality"/>
        </Button>
    </StackPanel>
</Window>